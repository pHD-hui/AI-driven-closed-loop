<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Lab Intelligent Hub</title>
    <style>
        :root {
            --primary: #2563eb; --primary-hover: #1d4ed8; --bg: #f3f4f6; --chat-bg: #ffffff;
            --user-msg: #eff6ff; --ai-msg: #f9fafb; --text-main: #1f2937; --text-light: #6b7280;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; }
        body { background-color: var(--bg); display: flex; justify-content: center; height: 100vh; padding: 20px; }

        .chat-container { width: 100%; max-width: 900px; background: var(--chat-bg); border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); display: flex; flex-direction: column; overflow: hidden; position: relative; }
        .header { padding: 20px; background: #fff; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 1.25rem; color: var(--text-main); display: flex; align-items: center; }
        .status-dot { display: inline-block; width: 10px; height: 10px; background-color: #10b981; border-radius: 50%; margin-right: 8px; }

        .chat-box { flex: 1; padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; scroll-behavior: smooth; }
        .message-row { display: flex; width: 100%; }
        .message-row.user { justify-content: flex-end; }
        .message { max-width: 80%; padding: 14px 18px; border-radius: 12px; line-height: 1.6; font-size: 0.95rem; color: var(--text-main); white-space: pre-wrap; word-wrap: break-word; }
        .message.user { background: var(--user-msg); border: 1px solid #bfdbfe; border-bottom-right-radius: 4px; }
        .message.ai { background: var(--ai-msg); border: 1px solid #e5e7eb; border-bottom-left-radius: 4px; }

        .task-card { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 16px; margin-top: 10px; font-size: 0.9rem; width: 100%; }
        .task-card .task-log { font-family: monospace; color: #166534; margin-bottom: 8px; }
        .finding-item { background: #fff; padding: 10px; border-radius: 6px; border-left: 4px solid #10b981; margin-top: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        .finding-tag { font-weight: bold; color: #047857; margin-bottom: 4px; display: inline-block;}

        /* Agent UI button group */
        .agent-actions { margin-top: 12px; display: flex; gap: 10px; }
        .btn-yes { background: #10b981; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;}
        .btn-yes:hover { background: #059669; }
        .btn-no { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; padding: 8px 16px; border-radius: 6px; cursor: pointer; }
        .btn-no:hover { background: #e5e7eb; }

        .input-area { padding: 15px 20px; background: #fff; border-top: 1px solid #e5e7eb; display: flex; align-items: center; gap: 12px; position: relative; }
        .tool-btn { background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 50%; width: 40px; height: 40px; font-size: 1.5rem; color: #4b5563; cursor: pointer; display: flex; justify-content: center; align-items: center; transition: all 0.2s; flex-shrink: 0; }
        .tool-btn:hover { background: #e5e7eb; color: var(--primary); }
        .mode-menu { position: absolute; bottom: 70px; left: 20px; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); width: 180px; display: none; flex-direction: column; overflow: hidden; z-index: 10; transform-origin: bottom left; animation: popup 0.2s ease-out; }
        @keyframes popup { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
        .mode-item { padding: 12px 16px; font-size: 0.95rem; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: background 0.2s; border-bottom: 1px solid #f3f4f6; }
        .mode-item:hover { background: #eff6ff; color: var(--primary); }

        .input-container { flex: 1; display: flex; align-items: center; background: #fff; border: 1px solid #d1d5db; border-radius: 24px; padding: 4px 14px; transition: border 0.2s; overflow: hidden; }
        .input-container.disabled { background: #f3f4f6; cursor: not-allowed; }
        .mode-badge { background: var(--primary); color: white; padding: 4px 10px; border-radius: 16px; font-size: 0.8rem; font-weight: bold; white-space: nowrap; margin-right: 8px; display: none; align-items: center; gap: 4px; }
        .input-container input { flex: 1; border: none; outline: none; padding: 10px 0; font-size: 1rem; width: 100%; background: transparent; }

        .send-btn { background: var(--primary); color: white; border: none; padding: 0 24px; height: 40px; border-radius: 24px; font-weight: 600; cursor: pointer; transition: background 0.2s; flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 6px; }
        .send-btn.cancel-mode { background: #ef4444; } /* red button when stopping extraction */
        .send-btn.cancel-mode:hover { background: #dc2626; }
        .send-btn:disabled { background: #9ca3af; cursor: not-allowed; }

        /* Left-right split layout */
        body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background-color: var(--bg); display: flex; justify-content: center; align-items: center; }
        .app-wrapper { display: flex; justify-content: center; margin: 0 auto; width: 100%; max-width: 1400px; height: 100vh; padding: 20px; gap: 20px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }

        /* PDF preview panel */
        .pdf-panel { flex: 0; width: 0; background: #fff; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); overflow: hidden; display: flex; flex-direction: column; opacity: 0; transform: translateX(20px); transition: all 0.4s ease; position: relative; }
        .app-wrapper.split-mode .pdf-panel { flex: 1; width: 50%; opacity: 1; transform: translateX(0); }
        .app-wrapper.split-mode .chat-container { flex: 1; max-width: none; }
        .pdf-header { padding: 15px 20px; background: #1f2937; color: #fff; font-weight: bold; font-size: 0.95rem; display: flex; justify-content: space-between; align-items: center; z-index: 2; }
        .pdf-viewer { flex: 1; position: relative; background: #f3f4f6; display: flex; justify-content: center; align-items: center; overflow: hidden; padding: 20px; }
        .pdf-viewer img { max-width: 100%; max-height: 100%; object-fit: contain; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-radius: 4px; transition: opacity 0.3s; }

        /* AI scan line animation */
        .scan-line { position: absolute; top: 0; left: 0; width: 100%; height: 6px; background: rgba(16, 185, 129, 0.7); box-shadow: 0 0 20px rgba(16, 185, 129, 1); display: none; z-index: 10; animation: scan 2.5s ease-in-out infinite alternate; border-radius: 50%; }
        @keyframes scan { 0% { top: 5%; } 100% { top: 95%; } }
        .is-scanning .scan-line { display: block; }

        /* Drag-and-drop upload overlay */
        .chat-container { position: relative; }
        .chat-container.drag-over::after { content: '📁 Release to upload PDF to the local library'; position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(255,255,255,0.95); z-index: 100; display: flex; justify-content: center; align-items: center; font-size: 1.5rem; color: var(--primary); font-weight: bold; border: 4px dashed var(--primary); border-radius: 16px; backdrop-filter: blur(5px); }

        /* Spinner animation */
        .btn-spinner { width: 16px; height: 16px; border: 2px solid #ffffff; border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: none; justify-content: center; align-items: center; z-index: 1000; backdrop-filter: blur(4px); }
        .modal { background: #fff; width: 90%; max-width: 600px; border-radius: 16px; padding: 30px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); text-align: center; }
        .modal h2 { margin-bottom: 15px; color: #10b981; }
        .close-btn { background: var(--primary); color: white; border: none; padding: 10px 30px; border-radius: 8px; cursor: pointer; margin-top: 20px;}
    </style>
</head>
<body>
<div class="app-wrapper" id="app-wrapper">

<div class="chat-container">
    <div class="header">
        <h1><span class="status-dot"></span>AI Lab Intelligent Hub</h1>
        <small style="color: var(--text-light)">Agent Extraction Console</small>
    </div>

    <div class="chat-box" id="chat-box">
        <div class="message-row ai">
            <div class="message ai">System initialized successfully. Click the <b>+</b> icon in the lower-left corner to select a mode, or just start chatting with me directly.</div>
        </div>
    </div>

    <div class="mode-menu" id="mode-menu">
        <div class="mode-item" onclick="setMode('normal', '', '')">💬 General Q&amp;A Mode</div>
        <div class="mode-item" onclick="setMode('extract', 'Help me search for: ', '📄 Literature Extraction')">📄 Literature Extraction Mode</div>
        <div class="mode-item" onclick="setMode('hardware', 'Hardware control: ', '⚙️ Hardware Control')">⚙️ Hardware Control Mode</div>
    </div>

    <div class="input-area">
        <button id="tool-btn" class="tool-btn">+</button>

        <label for="file-upload" class="tool-btn" style="margin-left:-8px; cursor:pointer;" title="Upload literature">📎</label>
        <input type="file" id="file-upload" accept=".pdf" style="display:none;" multiple>

        <div class="input-container" id="input-container">
            <div id="mode-badge" class="mode-badge"></div>
            <input type="text" id="user-input" placeholder="Enter a question or command..." autocomplete="off">
        </div>
        <button id="send-btn" class="send-btn">Send</button>
    </div>
</div>

<div class="pdf-panel" id="pdf-panel">
    <div class="pdf-header">
        <span>AI is reading...</span>
        <div style="display: flex; align-items: center; gap: 15px;">
            <span id="pdf-title" style="font-size:0.8rem; color:#9ca3af; font-weight:normal;">Waiting for connection...</span>
            <button id="close-pdf-btn" style="background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; padding: 0; line-height: 1;" title="Close preview panel">×</button>
        </div>
    </div>
    <div class="pdf-viewer" id="pdf-viewer">
        <div class="scan-line"></div>
        <img id="pdf-image" src="" alt="Waiting for AI reading view..." style="opacity: 0;">
    </div>
</div>

<div class="modal-overlay" id="summary-modal">
    <div class="modal">
        <h2>🎉 Parsing Task Completed</h2>
        <p id="summary-text" style="color: var(--text-light); line-height: 1.6;"></p>
        <button class="close-btn" onclick="document.getElementById('summary-modal').style.display='none'">OK</button>
    </div>
</div>

<script>
    const chatBox = document.getElementById('chat-box');
    const userInput = document.getElementById('user-input');
    const sendBtn = document.getElementById('send-btn');
    const toolBtn = document.getElementById('tool-btn');
    const modeMenu = document.getElementById('mode-menu');
    const modeBadge = document.getElementById('mode-badge');
    const inputContainer = document.getElementById('input-container');

    let currentMode = { id: 'normal', prefix: '', label: '' };

    toolBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        modeMenu.style.display = modeMenu.style.display === 'flex' ? 'none' : 'flex';
    });
    document.addEventListener('click', () => modeMenu.style.display = 'none');

    function setMode(id, prefix, label) {
        currentMode = { id, prefix, label };
        modeMenu.style.display = 'none';
        if (id === 'normal') {
            modeBadge.style.display = 'none';
            userInput.placeholder = 'Enter a question or command...';
        } else {
            modeBadge.innerHTML = `${label} <span style="cursor:pointer; margin-left:4px" onclick="event.stopPropagation(); setMode('normal','','')">×</span>`;
            modeBadge.style.display = 'flex';
            userInput.placeholder = 'Enter your request (leave blank for default)...';
        }
        userInput.focus();
    }

    sendBtn.addEventListener('click', sendMessage);
    userInput.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });

    async function sendMessage() {
        const text = userInput.value.trim();
        if (!text && currentMode.id === 'normal') return;

        const finalPayload = currentMode.prefix + text;
        const displayHtml = currentMode.id !== 'normal'
            ? `<span style="background:rgba(255,255,255,0.2); padding:2px 6px; border-radius:6px; font-size:0.85em; margin-right:5px;">${currentMode.label}</span> ${text || 'Passivators specialized for the FAPbI3 perovskite system'}`
            : text;

        appendMessageHtml(displayHtml, 'user');
        userInput.value = '';
        setNormalLoadingState(true);

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'chat', message: finalPayload })
            });

            setNormalLoadingState(false);
            const contentType = response.headers.get("content-type");

            if (contentType && contentType.indexOf("application/json") !== -1) {
                const data = await response.json();

                // Agent asks for schema field confirmation
                if (data.type === 'field_confirm') {
                    renderFieldConfirm(data.task_desc, data.fields, data.reply);
                }
                else if (data.type === 'task_trigger') {
                    appendMessage(data.reply, 'ai');
                    startTaskStream();
                } else {
                    appendMessage(data.reply, 'ai');
                }
            } else {
                const reader = response.body.getReader();
                const decoder = new TextDecoder('utf-8');
                const msgDiv = createMessageDiv('ai');
                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    msgDiv.textContent += decoder.decode(value, {stream: true});
                    scrollToBottom();
                }
            }
        } catch (error) {
            setNormalLoadingState(false);
            appendMessage('Network connection error.', 'ai');
        }
    }

    // =====================================
    // Schema confirmation logic
    // =====================================
    function renderFieldConfirm(taskDesc, fields, replyMsg) {
        // Must be written flush-left, otherwise spaces in the template string
        // will be rendered because of pre-wrap
        const html = `<div>
${replyMsg.replace(/\n/g, '<br>')}
<div class="agent-actions">
    <button class="btn-yes" onclick='confirmExtraction(${JSON.stringify(taskDesc)}, ${JSON.stringify(fields)}, this)'>✅ Confirm extraction using the fields above</button>
    <button class="btn-no" onclick='modifyExtraction(this)'>❌ Add or modify requirements</button>
</div>
</div>`;
        appendMessageHtml(html, 'ai');
    }

    async function confirmExtraction(taskDesc, fields, btnElement) {
        btnElement.parentElement.innerHTML = '<i>(User confirmed)</i>';
        appendMessageHtml("✅ Yes, please proceed according to this plan.", "user");

        setNormalLoadingState(true);
        const res = await fetch('/api/chat', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ action: 'start_extraction', task_desc: taskDesc, fields: fields })
        });
        setNormalLoadingState(false);

        const data = await res.json();
        if (data.type === 'task_trigger') {
            appendMessage(data.reply, 'ai');
            startTaskStream();
        }
    }

    function modifyExtraction(btnElement) {
        btnElement.parentElement.innerHTML = '<i>(User requested modifications)</i>';
        appendMessageHtml("❌ No, I need to revise the requirements.", "user");
        setMode('extract', 'Help me search for: ', '📄 Literature Extraction');
        userInput.placeholder = "Please enter your additional requirements directly, e.g. add certain fields...";
        userInput.focus();
    }

    // =====================================
    // Background extraction and interruption control
    // =====================================
    function startTaskStream() {
        setTaskRunningState(true);

        const eventSource = new EventSource('/api/task_stream');
        const row = document.createElement('div');
        row.className = 'message-row ai';
        const card = document.createElement('div');
        card.className = 'task-card';
        card.innerHTML = `<div class="task-log" id="current-log">Preparing to connect to the parsing engine...</div><div id="findings-container"></div>`;
        row.appendChild(card);
        chatBox.appendChild(row);

        const logEl = card.querySelector('#current-log');
        const findingsEl = card.querySelector('#findings-container');
        scrollToBottom();

        eventSource.onmessage = function(event) {
            const msg = JSON.parse(event.data);
            if (msg.type === 'info' || msg.type === 'progress') {
                logEl.textContent = `> ${msg.message}`;
            }
            else if (msg.type === 'page_reading') {
                document.getElementById('app-wrapper').classList.add('split-mode');
                document.getElementById('pdf-viewer').classList.add('is-scanning');
                document.getElementById('pdf-title').textContent = `${msg.data.filename} (Page ${msg.data.page})`;

                const imgEl = document.getElementById('pdf-image');
                imgEl.src = "data:image/jpeg;base64," + msg.data.image;
                imgEl.style.opacity = "1";
            }
            else if (msg.type === 'finding') {
                const d = msg.data;
                const findingDiv = document.createElement('div');
                findingDiv.className = 'finding-item';

                // Dynamically assemble JSON keys
                let detailsHtml = '';
                for(let key in d.details) {
                    if(key !== '_source_doc') {
                        detailsHtml += `<span style="color:#374151"><b>${key}:</b> ${d.details[key]}</span><br>`;
                    }
                }
                findingDiv.innerHTML = `<span class="finding-tag">🎯 New Finding (Page ${d.page})</span><br><div style="font-size:0.85rem; padding-left:10px; border-left:2px solid #e5e7eb; margin-top:5px;">${detailsHtml}</div>`;

                findingsEl.appendChild(findingDiv);
            } else if (msg.type === 'complete') {
                logEl.textContent = `✅ Extraction completed!`;
                logEl.style.color = '#047857';

                // Stop scan animation when done, but keep the screen for review
                document.getElementById('pdf-viewer').classList.remove('is-scanning');
                document.getElementById('pdf-title').textContent = "Task completed";

                eventSource.close();
                setTaskRunningState(false);
                showSummaryModal(msg.csv, msg.count);
            }
            scrollToBottom();
        };

        eventSource.onerror = function() {
            logEl.textContent = `⚠️ Connection lost.`;
            eventSource.close();
            setTaskRunningState(false);
        };
    }

    // Cancel task request
    async function requestCancelTask() {
        sendBtn.innerHTML = '<div class="btn-spinner"></div> Interrupting...';
        sendBtn.disabled = true;
        await fetch('/api/cancel_task', {method: 'POST'});
        // Wait for backend to finish and send complete automatically, then SSE will close
    }

    // =====================================
    // UI state control helpers
    // =====================================
    function setNormalLoadingState(isLoading) {
        userInput.disabled = isLoading;
        sendBtn.disabled = isLoading;
        inputContainer.classList.toggle('disabled', isLoading);
        sendBtn.innerHTML = isLoading ? '<div class="btn-spinner"></div>' : 'Send';
        if (!isLoading) userInput.focus();
    }

    function setTaskRunningState(isRunning) {
        if(isRunning) {
            userInput.disabled = true;
            inputContainer.classList.add('disabled');
            sendBtn.innerHTML = '<div class="btn-spinner"></div> Pause Extraction';
            sendBtn.className = 'send-btn cancel-mode';
            sendBtn.onclick = null;
            sendBtn.addEventListener('click', requestCancelTask);
        } else {
            userInput.disabled = false;
            inputContainer.classList.remove('disabled');
            sendBtn.innerHTML = 'Send';
            sendBtn.className = 'send-btn';
            sendBtn.removeEventListener('click', requestCancelTask);
            sendBtn.onclick = null;
            sendBtn.addEventListener('click', sendMessage);
            userInput.focus();
        }
    }

    function showSummaryModal(csvPath, count) {
        const textEl = document.getElementById('summary-text');
        textEl.innerHTML = `A total of <b>${count}</b> high-value records were extracted.<br><br>The complete data table has been saved in your project directory:<br><code style="background:#f3f4f6; padding:4px; border-radius:4px; font-size:0.9em; word-break:break-all;">${csvPath}</code>`;
        document.getElementById('summary-modal').style.display = 'flex';
    }

    function createMessageDiv(sender) {
        const row = document.createElement('div');
        row.className = `message-row ${sender}`;
        const msg = document.createElement('div');
        msg.className = `message ${sender}`;
        row.appendChild(msg);
        chatBox.appendChild(row);
        return msg;
    }

    function appendMessageHtml(html, sender) {
        const msgDiv = createMessageDiv(sender);
        msgDiv.innerHTML = html;
        scrollToBottom();
    }

    function appendMessage(text, sender) {
        const msgDiv = createMessageDiv(sender);
        msgDiv.textContent = text;
        scrollToBottom();
    }

    function scrollToBottom() {
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    // =====================================
    // Close PDF panel
    // =====================================
    document.getElementById('close-pdf-btn').addEventListener('click', () => {
        document.getElementById('app-wrapper').classList.remove('split-mode');
    });

    // =====================================
    // Drag-and-drop and upload logic
    // =====================================
    const fileUpload = document.getElementById('file-upload');
    const chatContainer = document.getElementById('chat-container');

    // Listen for paperclip click selection
    fileUpload.addEventListener('change', (e) => handleFiles(e.target.files));

    // Listen for drag events
    chatContainer.addEventListener('dragover', (e) => { e.preventDefault(); chatContainer.classList.add('drag-over'); });
    chatContainer.addEventListener('dragleave', (e) => { e.preventDefault(); chatContainer.classList.remove('drag-over'); });
    chatContainer.addEventListener('drop', (e) => {
        e.preventDefault();
        chatContainer.classList.remove('drag-over');
        handleFiles(e.dataTransfer.files);
    });

    async function handleFiles(files) {
        if (!files || files.length === 0) return;

        const formData = new FormData();
        let pdfCount = 0;

        for (let file of files) {
            if (file.type === "application/pdf" || file.name.toLowerCase().endsWith('.pdf')) {
                formData.append('files', file);
                pdfCount++;
            }
        }

        if (pdfCount === 0) {
            appendMessage('Only PDF-format literature files are supported.', 'ai');
            return;
        }

        appendMessage(`Archiving ${pdfCount} literature file(s) into the local knowledge base...`, 'user');

        try {
            const res = await fetch('/api/upload', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.status === 'success') {
                appendMessage(`✅ Archived successfully! You can issue extraction commands for them at any time.\n\nSaved files:\n${data.saved.join('\n')}`, 'ai');
            } else {
                appendMessage(`❌ Upload failed: ${data.error}`, 'ai');
            }
        } catch (e) {
            appendMessage('❌ Network error. Failed to connect to the local service.', 'ai');
        }

        fileUpload.value = '';
    }

</script>
</div>
</body>
</html>
